{
  "$schema": "https://json-schema.store.org/claude-code-settings.json",
  "env": {
    "VAULT_PATH": "__VAULT_PATH__",
    "COMPANY_NAME": "YourCompany",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "80000",
    "BASH_DEFAULT_TIMEOUT_MS": "600000"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "WebSearch",
      "NotebookRead",
      "NotebookEdit",
      "TodoWrite",
      "ExitPlanMode",
      "Task",
      "mcp__*"
    ],
    "deny": [],
    "ask": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /:*)",
      "Bash(sudo rm -rf /)",
      "Bash(sudo rm -rf /:*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf ~/.claude)",
      "Bash(rm -rf ~/.claude:*)",
      "Bash(dd if=/dev/zero:*)",
      "Bash(mkfs:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin --force:*)",
      "Bash(git push origin -f:*)",
      "Read(~/.ssh/id_*)",
      "Read(~/.ssh/*.pem)",
      "Read(~/.aws/credentials)",
      "Read(~/.gnupg/private*)",
      "Write(~/.claude/settings.json)",
      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/employee.json)",
      "Edit(~/.claude/employee.json)",
      "Write(~/.ssh/*)",
      "Edit(~/.ssh/*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/SecurityValidator.hook.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/SecurityValidator.hook.ts"
          },
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/AccessControl.hook.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/SecurityValidator.hook.ts"
          },
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/AccessControl.hook.ts"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/SecurityValidator.hook.ts"
          },
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/AccessControl.hook.ts"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/SecurityValidator.hook.ts"
          },
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/AccessControl.hook.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/PromptGuard.hook.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/IntegrityCheck.hook.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/VaultContext.hook.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun __HOOKS_DIR__/KnowledgeIngestion.hook.ts"
          }
        ]
      }
    ]
  }
}
